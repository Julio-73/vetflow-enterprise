# ==============================================================================
# VetFlow SaaS Environment Variables Example Configuration
# ==============================================================================
# Copy this file to .env and fill in the values for local development.

# Application General Config
PORT=3000
APP_ENV=development
CLIENT_URL=http://localhost:5173

# Database Connection (PostgreSQL / Supabase)
# DATABASE_URL: Typically points to the transaction pooler (PgBouncer port 6543)
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT_DATABASE_URL: Bypasses the pooler, used exclusively for running DDL migrations (Direct port 5432)
DIRECT_DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Supabase API Credentials
SUPABASE_URL="https://[YOUR_PROJECT_ID].supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_anon_key_here..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_service_role_key_here..."

# Authentication & Security
JWT_SECRET="your_jwt_signing_secret_min_32_characters_here_12345"
JWT_EXPIRES_IN="1d"

# Integration Webhooks (e.g., WhatsApp Cloud API, Payment Gateways)
WHATSAPP_VERIFY_TOKEN="your_whatsapp_webhook_verify_token"
WHATSAPP_API_TOKEN="your_whatsapp_cloud_api_token"
MERCADOPAGO_ACCESS_TOKEN="your_mercadopago_token_for_latam"
KUSHKI_PRIVATE_KEY="your_kushki_private_key"
